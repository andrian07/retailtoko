<script>
 $('#save_note').click(function(e){
    e.preventDefault();
    var comment  = $("#comment").val();
    $.ajax({
      type: "POST",
      url: "<?php echo base_url(); ?>Dashboard/save_comment",
      dataType: "json",
      data: {comment:comment},
      success : function(data){
        if (data.code == "200"){
          window.location.href = "<?php echo base_url(); ?>/Dashboard/Admin";
        } else {
          Swal.fire({
            icon: 'error',
            title: 'Oops...',
            text: data.result,
          })
        }
      }
    });
  });
  </script>